# Copy this file to `.env` (already in .gitignore) and fill in the values you need.
# `app.py` loads .env at startup via python-dotenv, so changes take effect on server restart.

# ── Anthropic Claude (only needed for `mode=anthropic`) ──
# Get one at https://console.anthropic.com — starts with `sk-ant-...`
ANTHROPIC_API_KEY=

# ── Google OAuth (only needed for "Continue with Google") ──
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Choose "Web application", and add this exact redirect URI to "Authorized redirect URIs":
#   http://localhost:8000/api/auth/google/callback
# Without these, the dummy dev flow is used (logs you in as dev@example.com).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Local-only dev escape hatch ──
# When set to 1, requests from 127.0.0.1/::1/localhost are treated as developer
# sessions even without a `users.is_developer = 1` flag. NEVER set this in prod
# behind a proxy — it'll grant dev to anyone.
LOCAL_DEV_BYPASS=

# ── Bind host + port for `python app.py` ──
# Default deploy binds 0.0.0.0:8000 (matches the Pi's systemd unit). Override
# when a local dev's port 8000 is taken (e.g. another project's server).
JOBS_AI_HOST=0.0.0.0
JOBS_AI_PORT=8000

# ── SMTP (optional — Phase 7 emails the run report) ──
# All five must be set together; if any is missing, email is silently skipped.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# ── Job ingestion: keyed APIs (huge volume boost when set) ──
# Each is optional — sources whose keys are missing silently skip registration.

# USAJobs.gov — register at https://developer.usajobs.gov/APIRequest/Index
# USER_AGENT must match the email you registered with.
USAJOBS_USER_AGENT=
USAJOBS_API_KEY=

# Adzuna — https://developer.adzuna.com/  (need both)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed.co.uk — https://www.reed.co.uk/developers
REED_API_KEY=

# Jooble — https://jooble.org/api/about
JOOBLE_API_KEY=

# Findwork.dev — https://findwork.dev/developers/
FINDWORK_API_KEY=

# ── Stripe billing (Pro $4/month subscription) ──
# Required for the Plans page upgrade button and the /api/webhooks/stripe
# endpoint. Get keys at https://dashboard.stripe.com/apikeys (use sk_test_…
# while developing, sk_live_… in production).
STRIPE_SECRET_KEY=

# Recurring price for Pro. After setting STRIPE_SECRET_KEY, run
#   python scripts/setup_stripe.py
# once — it creates the Product + $4/mo Price and prints the price_id to
# paste here. Without this set, /api/billing/checkout returns 503.
STRIPE_PRICE_ID_PRO_MONTHLY=

# Used by /api/webhooks/stripe to verify event authenticity. For local dev
# run `stripe listen --forward-to http://localhost:8000/api/webhooks/stripe`
# — it prints a `whsec_…` value to drop in here. For production, take the
# signing secret from your dashboard webhook endpoint config. The two are
# DIFFERENT secrets — match the env to wherever the events are coming from.
STRIPE_WEBHOOK_SECRET=

# Public origin used for Checkout success / cancel redirects and the Stripe
# Customer Portal return URL. Required behind a proxy (Tailscale Funnel,
# Cloudflare, etc.) where FastAPI sees the internal address. For local-only
# dev, leave blank — the request URL is used.
PUBLIC_BASE_URL=
