# Copy this file to `.env` (already in .gitignore) and fill in the values you need.
# `app.py` loads .env at startup via python-dotenv, so changes take effect on server restart.

# ── Anthropic Claude (only needed for `mode=anthropic`) ──
# Get one at https://console.anthropic.com — starts with `sk-ant-...`
ANTHROPIC_API_KEY=

# ── Google OAuth (only needed for "Continue with Google") ──
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Choose "Web application", and add this exact redirect URI to "Authorized redirect URIs":
#   http://localhost:8000/api/auth/google/callback
# Without these, the dummy dev flow is used (logs you in as dev@example.com).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Local-only dev escape hatch ──
# When set to 1, requests from 127.0.0.1/::1/localhost are treated as developer
# sessions even without a `users.is_developer = 1` flag. NEVER set this in prod
# behind a proxy — it'll grant dev to anyone.
LOCAL_DEV_BYPASS=

# ── SMTP (optional — Phase 7 emails the run report) ──
# All five must be set together; if any is missing, email is silently skipped.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# ── Job ingestion: keyed APIs (huge volume boost when set) ──
# Each is optional — sources whose keys are missing silently skip registration.

# USAJobs.gov — register at https://developer.usajobs.gov/APIRequest/Index
# USER_AGENT must match the email you registered with.
USAJOBS_USER_AGENT=
USAJOBS_API_KEY=

# Adzuna — https://developer.adzuna.com/  (need both)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed.co.uk — https://www.reed.co.uk/developers
REED_API_KEY=

# Jooble — https://jooble.org/api/about
JOOBLE_API_KEY=

# Findwork.dev — https://findwork.dev/developers/
FINDWORK_API_KEY=
