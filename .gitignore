__pycache__/
*.pyc
*.pyo
*.pyd
.env
*.egg-info/
dist/
build/
.venv/
venv/
output/jobs_ai_sessions.sqlite3*
output/sessions/

# Live session DB (now lives in data/) and cached resume profiles — both
# contain user PII / auth tokens, never commit.
data/
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.corrupt-*
resources/profile_cache_*.json

# Runtime / test scratch — never commit. test_cookies.txt holds session
# bearer tokens from the integration suite; test_signup_resp.json holds
# generated user emails. Server.log + app_import_err.txt are diagnostic
# spew. .coverage is the pytest-cov binary db.
.coverage
.coverage.*
htmlcov/
server.log
app_import_err.txt
test_cookies.txt
test_signup_resp.json
.claude/scheduled_tasks.lock
